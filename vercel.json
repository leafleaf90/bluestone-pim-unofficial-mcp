{
  "fluid": true,
  "outputDirectory": "build",
  "functions": {
    "api/mcp.ts": {
      "maxDuration": 300
    }
  },
"rewrites": [
    { "source": "/", "destination": "/api/mcp" },
    { "source": "/mcp", "destination": "/api/mcp" },
    { "source": "/authorize", "destination": "/api/mcp" },
    { "source": "/token", "destination": "/api/mcp" },
    { "source": "/register", "destination": "/api/mcp" },
    { "source": "/.well-known/oauth-authorization-server", "destination": "/api/mcp" },
    { "source": "/.well-known/oauth-protected-resource", "destination": "/api/mcp" }
  ]
}
